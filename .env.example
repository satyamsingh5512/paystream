# ============================================================================
# PayStream — environment variable template
# Copy to `.env` (cp .env.example .env) and adjust as needed.
# NEVER commit the real .env file. Replace all secrets before any non-local use.
# ============================================================================

# ---- Image tag ----
TAG=latest

# ---- Database credentials (shared across all Postgres instances) ----
DB_USER=paystream
DB_PASS=paystream
DB_NAME_AUTH=auth_db
DB_NAME_ACCOUNT=account_db
DB_NAME_TRANSACTION=transaction_db
DB_NAME_FRAUD=fraud_db
DB_NAME_LEDGER=ledger_db

# ---- Database hosts (compose service names; override for external DBs) ----
DB_HOST_AUTH=postgres-auth
DB_HOST_ACCOUNT=postgres-account
DB_HOST_TRANSACTION=postgres-transaction
DB_HOST_FRAUD=postgres-fraud
DB_HOST_LEDGER=postgres-ledger

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_HOST_PORT=29092

# ---- Service discovery / config ----
EUREKA_HOST=eureka-server
EUREKA_PORT=8761
EUREKA_SELF_PRESERVATION=false
CONFIG_SERVER_URI=http://config-server:8888
CONFIG_SERVER_PORT=8888

# ---- API Gateway ----
API_GATEWAY_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
JWK_SET_URI=http://auth-service:8081/.well-known/jwks.json
RATE_LIMIT_REPLENISH=20
RATE_LIMIT_BURST=40

# ---- Internal service-to-service shared secret (override in production) ----
INTERNAL_API_KEY=changeit-internal-key

# ---- Auth service (JWT) ----
# Leave blank for a dev-only in-memory RSA key. For production, generate a key pair and
# point both at PEM resources (file:/... or classpath:...):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_LOCATION=
JWT_PUBLIC_KEY_LOCATION=
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ---- Mail (notification-service fallback; MailHog for local dev) ----
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_SMTP_AUTH=false
MAIL_STARTTLS=false
MAILHOG_UI_PORT=8025

# ---- Observability ----
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
